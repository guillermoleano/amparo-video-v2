{
  "name": "amparo-video-v2",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "remotion studio src/index.ts",
    "typecheck": "tsc --noEmit",
    "still:dia-imposible": "remotion still src/index.ts DiaImposible out/dia-imposible.png --frame=150",
    "render:dia-imposible": "remotion render src/index.ts DiaImposible out/dia-imposible.mp4",
    "still:clientes-frustrados": "remotion still src/index.ts ClientesFrustrados out/clientes-frustrados.png --frame=165",
    "render:clientes-frustrados": "remotion render src/index.ts ClientesFrustrados out/clientes-frustrados.mp4",
    "still:burnout": "remotion still src/index.ts Burnout out/burnout.png --frame=90",
    "render:burnout": "remotion render src/index.ts Burnout out/burnout.mp4",
    "still:el-sueno": "remotion still src/index.ts ElSueno out/el-sueno.png --frame=250",
    "render:el-sueno": "remotion render src/index.ts ElSueno out/el-sueno.mp4",
    "still:el-encuentro": "remotion still src/index.ts ElEncuentro out/el-encuentro.png --frame=260",
    "render:el-encuentro": "remotion render src/index.ts ElEncuentro out/el-encuentro.mp4",
    "still:despertar": "remotion still src/index.ts Despertar out/despertar.png --frame=150",
    "render:despertar": "remotion render src/index.ts Despertar out/despertar.mp4",
